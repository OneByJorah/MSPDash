# MSPDash — Environment Configuration
# Copy this file to .env and fill in your values.

# ── Dashboard ──────────────────────────────────────────────
COMPOSE_PROJECT_NAME=MSPDash
ADMIN_USER=admin
ADMIN_PASSWORD_BCRYPT=change_me_bcrypt_hash
SECRET_KEY=change_me_generate_random_secret
DASHBOARD_PORT=3000
API_PORT=42000

# ── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql://msp:change_me_db_password@timescaledb:5432/msp
POSTGRES_USER=msp
POSTGRES_PASSWORD=change_me_db_password
POSTGRES_DB=msp

# ── Telegram (optional) ──────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# ── Logging ────────────────────────────────────────────────
LOG_LEVEL=INFO
